			related_bias_pin : VNW;
			pg_type : primary_power;
		}
		
		pg_pin(VSS) {
			voltage_name : VSS;
			related_bias_pin : VPW;
			pg_type : primary_ground;
		}
		
		pin (ENA) {
			direction : input;
			clock : "true";
			related_ground_pin : "VSS";
			related_power_pin : "VDD";
			max_transition : 1.0;

		}
		
		pin (D) {
			direction : input;
			clock : "false";
			related_ground_pin : "VSS";
			related_power_pin : "VDD";
			max_transition : 1.0;

		}
		
		pin (Q) {
			direction : output;
			function : "IQ";
			related_ground_pin : "VSS";
			related_power_pin : "VDD";
			max_transition : 1.5;

		}
	}
	
